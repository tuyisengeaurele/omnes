# Server
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://omnes_user:change_this_password@localhost:5432/omnes_db

# JWT
JWT_ACCESS_SECRET=change_this_to_a_random_64_char_string_abcdefghijklmnopqrstuvwxyz123456
JWT_REFRESH_SECRET=change_this_to_a_different_random_64_char_string_abcdefghijklmnopq
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Logo
LOGO_PATH=/app/uploads/logo.png
